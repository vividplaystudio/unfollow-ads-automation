#!/bin/bash
# Copy this file to config.sh, fill in your real values, then:
#   chmod 600 config.sh
# (so only you can read it — important, contains API tokens)

# ─── Where to write the JSON files ─────────────────────────────────
# Absolute path to your dashboard folder. The scripts will write
# data.json / meta_ads.json / adjust.json directly here.
# Find your real path with `pwd` from inside the dashboard folder.
export LOCAL_OUTPUT_DIR="/home/CHANGE_ME/public_html/ads-dashboard"

# ─── Meta (Facebook) Marketing API ─────────────────────────────────
export META_ACCESS_TOKEN="CHANGE_ME"
export META_AD_ACCOUNT_ID="2399779997191076"

# ─── Adjust Reports Service API ────────────────────────────────────
export ADJUST_API_TOKEN="CHANGE_ME"
export ADJUST_APP_TOKEN="pbu6v5dz9yww"

# ─── RevenueCat (only needed for the slow `rc` refresher) ──────────
export REVENUECAT_API_KEY="CHANGE_ME"
export REVENUECAT_PROJECT_ID="6afc72a9"
export RC_WEBHOOK_SECRET="CHANGE_ME"
export RC_EVENTS_URL="https://genivox.com/ads-upload/rc_events.php"

# ─── Apple Search Ads (only needed for the `rc` refresher) ─────────
# Plus this also reads ASA token from a Google Sheet — skip if you're
# not actively using ASA. Without these, the rc script will error on
# the ASA fetch but with our continue-on-error setup that's OK.
export SPREADSHEET_ID="CHANGE_ME_OR_LEAVE_BLANK"
export GOOGLE_SERVICE_ACCOUNT_JSON='CHANGE_ME_OR_LEAVE_BLANK'
export ASA_ORG_ID="8868820"
